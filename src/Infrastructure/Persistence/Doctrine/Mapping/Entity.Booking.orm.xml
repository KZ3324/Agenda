<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping">
    <entity name="App\Domain\Entity\Booking" table="bookings">
        <id name="id" column="id" type="booking_id"/>
        <field name="customerName" type="string" column="customer_name" />
        <field name="status" type="string" column="status" />
        <embedded name="dates" class="App\Domain\ValueObject\BookingDate" use-column-prefix="false" />

    </entity>
</doctrine-mapping>